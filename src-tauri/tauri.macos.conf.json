{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "npm run sidecars:prepare && npm run dev",
    "beforeBuildCommand": "npm run sidecars:prepare && npm run build"
  },
  "bundle": {
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "resources": [
      "third-party/FFMPEG-NOTICE.md",
      "binaries/COPYING.FFMPEG-GPLv2",
      "binaries/COPYING.X264-GPLv2",
      "binaries/COPYING.LAME-LGPLv2"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "Entitlements.plist"
    }
  }
}
